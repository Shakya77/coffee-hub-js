}

### assign vendor role to the same user
# Replace these ids with the actual user id and vendor role id from your database.
POST {{baseUrl}}/user-has-roles
Content-Type: application/json

{
    "userId": 1,
    "roleId": 3,
    "businessType": "Roastery",
    "businessName": "Multi Role Coffee"
}

### login user (copy access_token into @authToken)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "admin@coffeehub.com",
    "password": "admin123"
}

### get auth profile
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{authToken}}

### get auth role
GET {{baseUrl}}/auth/role
Authorization: Bearer {{authToken}}

### get all user roles (for multi-role switching)
GET {{baseUrl}}/auth/roles
Authorization: Bearer {{authToken}}

### get all users
GET {{baseUrl}}/users
Authorization: Bearer {{authToken}}

### get user by id
GET {{baseUrl}}/users/1
Authorization: Bearer {{authToken}}

### update user by id
PATCH {{baseUrl}}/users/1
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "name": "Admin User Updated",
    "isActive": true
}

### delete user by id
DELETE {{baseUrl}}/users/1
Authorization: Bearer {{authToken}}